# Docker config
# prod: Dockerfile, dev: Dockerfile.dev
DOCKERFILE=Dockerfile.dev
ENABLE_CACHE=true
ENABLE_DB=true
RUST_LOG=info

# Postgres
POSTGRES_DB=myrtle
POSTGRES_USER=myrtle
POSTGRES_PASSWORD=myrtle

# Backend
DATABASE_URL=postgres://myrtle:myrtle@postgres:5432/myrtle
REDIS_URL=redis://redis:6379

# Base output dir; the backend loads each server from {ASSETS_DIR}/{server}
# (and {ASSETS_DIR}/{server}/gamedata/excel). The mounted ./assets/output must
# contain a subdir per configured server.
ASSETS_DIR=/data/output
# Servers to load (first = default). `bili` aliases `cn` automatically. Every
# listed server needs its data present, or startup fails.
SERVERS=en,cn
# Per-server hot-reload WebSockets: one asset-pipeline `ws` per server. Empty
# disables hot-reload. From the backend container, reach a host-run pipeline via
# host.docker.internal, e.g.
# ASSET_WS_URLS=en=ws://host.docker.internal:9160,cn=ws://host.docker.internal:9161
ASSET_WS_URLS=
# Single-server tooling (dps-tools profile / admin bins) reads this EN reference.
GAME_DATA_DIR=/data/output/en/gamedata/excel

JWT_SECRET=sample-jwt-secret-key
SERVICE_KEY=sample-internal-service-key

# Frontend
# Follows schema in frontend/src/env.js
BACKEND_URL=http://backend:3060

# Workaround profile
COMPOSE_PROFILES=true
