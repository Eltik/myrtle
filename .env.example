# Docker config
# prod: Dockerfile, dev: Dockerfile.dev
DOCKERFILE=Dockerfile.dev
ENABLE_CACHE=true
ENABLE_DB=true
RUST_LOG=info

# Postgres
POSTGRES_DB=myrtle
POSTGRES_USER=myrtle
POSTGRES_PASSWORD=myrtle

# Backend
DATABASE_URL=postgres://myrtle:myrtle@postgres:5432/myrtle
REDIS_URL=redis://redis:6379

ASSETS_DIR=/data/output
SERVERS=en,cn
ASSET_WS_URLS=en=ws://asset-watcher-en:9160,cn=ws://asset-watcher-cn:9161
GAME_DATA_DIR=/data/output/en/gamedata/excel

JWT_SECRET=sample-jwt-secret-key
SERVICE_KEY=sample-internal-service-key

# Frontend
# Follows schema in frontend/src/env.js
BACKEND_URL=http://backend:3060
VITE_BACKEND_URL=http://localhost:3060

# Discord bot (profile: discord). Needs a real token to start; config.json is
# mounted from ./discord/config.json. In that config, point assets.servers at the
# asset pipeline - a host-run pipeline is ws://host.docker.internal:<port>.
DISCORD_TOKEN=
# Discord's own SQLite DB (persisted in the myrtle_discorddata volume).
DISCORD_DATABASE_URL=sqlite:/data/discord.sqlite

# Compose profiles to enable. `true` = always-on app (postgres, redis, backend,
# frontend). Add others as needed, e.g. COMPOSE_PROFILES=true,discord,assets
#   discord = the bot; assets = live per-server asset-ws pipelines;
#   tools = dps-tools/asset-tools (manual one-off jobs).
COMPOSE_PROFILES=true
