# Docker config
# prod: Dockerfile, dev: Dockerfile.dev
DOCKERFILE=Dockerfile.dev
ENABLE_CACHE=true
ENABLE_DB=true
RUST_LOG=info

# Postgres
POSTGRES_DB=myrtle
POSTGRES_USER=myrtle
POSTGRES_PASSWORD=myrtle

# Backend
DATABASE_URL=postgres://myrtle:myrtle@postgres:5432/myrtle
REDIS_URL=redis://redis:6379

ASSETS_DIR=/data/output
SERVERS=en,cn
ASSET_WS_URLS=en=ws://asset-watcher-en:9160,cn=ws://asset-watcher-cn:9161
GAME_DATA_DIR=/data/output/en/gamedata/excel

JWT_SECRET=sample-jwt-secret-key
SERVICE_KEY=sample-internal-service-key

# Frontend
# Follows schema in frontend/src/env.js
BACKEND_URL=http://backend:3060
VITE_BACKEND_URL=http://localhost:3060

# Workaround profile
COMPOSE_PROFILES=true
