# Postgres connection string (panics on startup if unset).
DATABASE_URL="postgresql://postgres:password@localhost:5432"

# JWT signing secret for user tokens (panics on startup if unset).
JWT_SECRET="some-secret"

# Shared secret for internal service-to-service auth (panics on startup if unset).
SERVICE_KEY="some-key"

# Root (base) directory of processed assets. Per-server data loads from
# `{ASSETS_DIR}/{server}` (+ `/gamedata/excel` for the gamedata excel JSONs).
ASSETS_DIR="../assets/output"

# Servers to load at startup (comma-separated; first = default). e.g. "en,cn".
SERVERS="en"

# Server that standalone bins (regrade-users, resync-gacha, generate-dps) load
# game data for. Defaults to the first SERVERS entry (else "en").
#BIN_SERVER="en"

# WebSocket URL the asset hot-reload watcher connects to.
# Set to "disabled" or leave empty to skip the watcher.
ASSET_WS_URL="ws://localhost:9160"

# Redis connection string. If unset or unreachable, the server falls back to
# an in-memory cache (single-process only - not safe for multi-instance deploys).
REDIS_URL=redis://127.0.0.1:6379

# Per-IP requests-per-minute cap. Default: 100.
RATE_LIMIT_RPM=100

# Tracing filter (e.g. "backend=debug,tower_http=info"). Default: "backend=info,tower_http=info".
# RUST_LOG="backend=info,tower_http=info"

# How often the trending job runs, in seconds. Default: 900 (15 min).
TRENDING_RECOMPUTE_SECS=900

# How many entries to surface in the trending list. Default: 10.
TRENDING_TOP_N=10

# How often every user's grade is recomputed, in seconds. Default: 86400 (24h).
# Stage scores depend on aggregate completion, so grades drift over time.
REGRADE_INTERVAL_SECS=86400

# Max users regraded in parallel. Default: 4. Bound the DB pool: each task may
# fan out several queries via calculate_user_grade.
REGRADE_CONCURRENCY=4

# Users fetched per keyset page. Default: 500.
REGRADE_PAGE_SIZE=500

# Path to the JSON file that stores the last-run timestamp. Default: regrade_state.json
# (relative to the server's working dir). Used to avoid re-running on every restart.
REGRADE_STATE_FILE=regrade_state.json

# Polling interval against the upstream DPS repo, in seconds.
# UNSET DISABLES THE WATCHER ENTIRELY (no default).
DPS_POLL_INTERVAL=1800

# Upstream GitHub repo to poll. Default: "WhoAteMyCQQkie/ArknightsDpsCompare".
# DPS_UPSTREAM_REPO=WhoAteMyCQQkie/ArknightsDpsCompare

# Branch to track. Default: "main".
# DPS_UPSTREAM_BRANCH=main

# Local checkout path for the upstream repo. Default: "external/ArknightsDpsCompare".
# DPS_LOCAL_REPO_PATH=external/ArknightsDpsCompare

# Watcher state file (last-seen commit SHA, failure count). Default: ".dps-updater-state.json".
# DPS_STATE_FILE=.dps-updater-state.json

# Rebuild the DPS engine on new commits. Default: true. Set "false" or "0" to disable.
DPS_AUTO_BUILD=true

# Restart the server process after a successful rebuild. Default: false. Set "true" or "1" to enable.
DPS_AUTO_RESTART=true

# Optional GitHub PAT — raises the API rate limit from 60/h (anonymous) to 5000/h.
# GITHUB_TOKEN=ghp_xxx

# Arknights device identity. Must stay stable across restarts: the game binds a
# minted session `secret` to the requesting device, so a changing device id
# breaks re-minting from a stored session (and can trip device-change checks).
#
# By default the device ids are generated once and persisted to this JSON file
# (auto-created, relative to the working dir), then reused on every restart.
# DEVICE_IDS_FILE=device_ids.json
#
# To pin a device explicitly (e.g. ephemeral containers with no persistent
# volume), set all three; this takes priority over the file and is not written.
# DEVICE_ID=
# DEVICE_ID2=
# DEVICE_ID3=

DISABLE_BACKGROUND_JOBS=1

DISCORD_TOKEN=""
DISCORD_ID=""
DISCORD_REDIRECT_URI="https://api.myrtle.moe/api/auth/discord/callback"
